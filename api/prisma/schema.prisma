// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite doesn't support enums, using String with validation in code
// ENUM: LOW, MEDIUM, HIGH, URGENT
// ENUM: PENDING, IN_PROGRESS, DONE
// ENUM: SHOW_ROOM, MOVE_IN, MOVE_OUT, MAINTENANCE_CHECK, MAINTENANCE_SUPERVISION, PAYMENT_COLLECTION, ROOM_INSPECTION, FOLLOW_UP

model Organization {
  id        String     @id @default(uuid())
  name      String
  buildings Building[]
  users     User[]
  contracts Contract[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  password       String
  name           String
  role           String       // ADMIN, MANAGER, TECHNICIAN
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  tasks          Task[]       @relation("AssignedTasks")
  contracts      Contract[]   @relation("ManagedContracts")
  feedbacks      Feedback[]
  createdAt      DateTime     @default(now())

  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
}

model Building {
  id             String       @id @default(uuid())
  name           String
  address        String
  latitude       Float?
  longitude      Float?
  clusterId      String?      // Cụm: Đống Đa, Ba Đình, Hai Bà Trưng, v.v.
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  rooms          Room[]
  tasks          Task[]
  contracts      Contract[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  ledgerEntries  LedgerEntry[]
}

model Room {
  id          String     @id @default(uuid())
  number      String
  floor       Int
  buildingId  String
  building    Building   @relation(fields: [buildingId], references: [id])
  tasks       Task[]
  contracts   Contract[]
  status      String     // Occupied, Empty, Pending, Maintenance (Status_Matrix)
  createdAt   DateTime   @default(now())
  updatedAt      DateTime     @updatedAt
  ledgerEntries  LedgerEntry[]
  utilityReadings UtilityReading[]
  violations      Violation[]
}

model Task {
  id                String     @id @default(uuid())
  type              String
  priority          String     @default("MEDIUM")
  status            String     @default("PENDING")
  scheduledTime     DateTime?
  estimatedDuration Int?       // in minutes
  
  description       String?
  notes             String?
  
  organizationId    String
  buildingId        String
  building          Building   @relation(fields: [buildingId], references: [id])
  roomId            String?
  room              Room?      @relation(fields: [roomId], references: [id])
  
  assignedManagerId String?
  assignedManager   User?      @relation("AssignedTasks", fields: [assignedManagerId], references: [id])
  
  latitude          Float?
  longitude         Float?

  beforeImage       String?
  afterImage        String?
  
  startTime         DateTime?
  endTime           DateTime?
  
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?
  logs              ActivityLog[]
  feedbacks         Feedback[]
}


// Khách thuê
model Tenant {
  id               String    @id @default(uuid())
  name             String
  phone            String?
  idCard           String?   // CMND/CCCD
  email            String?
  isRepresentative Boolean   @default(false) // Người đại diện ký hợp đồng
  notes            String?   // Ghi chú thêm về người ở
  contractId       String
  contract         Contract  @relation(fields: [contractId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// Hợp đồng thuê phòng
model Contract {
  id              String    @id @default(uuid())
  // Status flow: CONSULTING → DEPOSIT_REQUESTED → DEPOSITED → CONTRACT_SIGNED → ACTIVE → ENDED
  status          String    @default("CONSULTING")
  contractType    String?   // 3M, 6M, 12M (For commission automation)

  // Tài chính
  monthlyRent     Float?    // Giá thuê/tháng
  depositAmount   Float?    // Tiền đặt cọc
  depositDate     DateTime? // Ngày đặt cọc

  // Thời gian
  moveInDate      DateTime? // Ngày nhận phòng
  startDate       DateTime? // Ngày bắt đầu hợp đồng
  endDate         DateTime? // Ngày kết thúc hợp đồng

  // Ảnh chụp hợp đồng giấy — gửi về kế toán
  contractImages  String?   // JSON array of image URLs

  // Ghi chú vận hành
  notes           String?

  // Relations
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  buildingId      String
  building        Building     @relation(fields: [buildingId], references: [id])
  roomId          String
  room            Room         @relation(fields: [roomId], references: [id])
  managerId       String
  manager         User         @relation("ManagedContracts", fields: [managerId], references: [id])
  tenants         Tenant[]
  feedbacks       Feedback[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  invoices        Invoice[]
  ledgerEntries   LedgerEntry[]
  violations      Violation[]
}

model Account {
  id        String   @id // e.g., "111", "3386"
  name      String
  type      String   // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  level     Int      @default(1)
  parentId  String?
  parent    Account? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children  Account[] @relation("AccountHierarchy")
  
  debitEntries  LedgerEntry[] @relation("DebitAccount")
  creditEntries LedgerEntry[] @relation("CreditAccount")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LedgerEntry {
  id              String   @id @default(uuid())
  date            DateTime @default(now())
  description     String
  amount          Float
  
  debitAccountId  String
  debitAccount    Account  @relation("DebitAccount", fields: [debitAccountId], references: [id])
  
  creditAccountId String
  creditAccount   Account  @relation("CreditAccount", fields: [creditAccountId], references: [id])
  
  contractId      String?
  contract        Contract? @relation(fields: [contractId], references: [id])
  
  roomId          String?
  room            Room?      @relation(fields: [roomId], references: [id])
  
  buildingId      String?
  building        Building?  @relation(fields: [buildingId], references: [id])
  
  invoiceId       String?
  invoice         Invoice?   @relation(fields: [invoiceId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Invoice {
  id          String   @id @default(uuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id])
  
  period      String   // e.g., "2026-03"
  dueDate     DateTime
  status      String   @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE, CANCELLED
  
  items       String?  // JSON string
  totalAmount Float
  
  ledgerEntries LedgerEntry[]
  utilityReadings UtilityReading[]
  violations      Violation[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UtilityReading {
  id            String   @id @default(uuid())
  roomId        String
  room          Room     @relation(fields: [roomId], references: [id])
  
  type          String   // ELECTRICITY, WATER
  readingDate   DateTime @default(now())
  previousValue Float
  currentValue  Float
  consumption   Float
  rate          Float
  amount        Float
  
  invoiceId     String?
  invoice       Invoice? @relation(fields: [invoiceId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Violation {
  id          String   @id @default(uuid())
  type        String   // ELECTRICITY, LAUNDRY, NOISE, etc.
  count       Int      @default(1) // Lần 1, Lần 2...
  amount      Float    @default(0)
  description String?
  date        DateTime @default(now())
  
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id])
  
  contractId  String?
  contract    Contract? @relation(fields: [contractId], references: [id])
  
  invoiceId   String?
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model ActivityLog {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  action    String
  userId    String
  payload   String?
  createdAt DateTime @default(now())
}

model Feedback {
  id           String   @id @default(uuid())
  content      String
  type         String   @default("CHAT") // CHAT, SYSTEM, ALERT
  category     String?  // UTILITY, MAINTENANCE, GENERAL
  images       String?  // JSON array of image URLs
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  taskId       String?
  task         Task?    @relation(fields: [taskId], references: [id])
  contractId   String?
  contract     Contract? @relation(fields: [contractId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


